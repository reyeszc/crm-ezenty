# ─── BASE DE DATOS (OBLIGATORIO) ──────────────────────────────────────────
# Crea una base de datos Postgres gratis en Neon (neon.tech):
# 1. Ve a https://neon.tech y crea una cuenta gratis (sin tarjeta)
# 2. Crea un nuevo proyecto
# 3. Copia la "Connection string" que empieza con postgresql://
# 4. Pégala aquí
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# ─── SECRETO DE SESIONES (OBLIGATORIO) ───────────────────────────────────
# Texto largo y aleatorio para firmar las sesiones.
# En tu terminal corre: openssl rand -base64 32
# Pega el resultado aquí
AUTH_SECRET="CAMBIA_ESTO_POR_UN_TEXTO_LARGO_Y_ALEATORIO"

# ─── URL DE TU APP (OBLIGATORIO EN PRODUCCIÓN) ────────────────────────────
NEXTAUTH_URL="https://tu-app.vercel.app"

# ─── ASISTENTE DE IA (OPCIONAL) ───────────────────────────────────────────
# El CRM funciona sin esto. Si quieres el asistente de IA real:
# 1. Ve a https://console.anthropic.com → API Keys
# 2. Crea una nueva llave y pégala aquí
# Sin esta llave, el asistente usa plantillas inteligentes locales.
ANTHROPIC_API_KEY=""

# ─── GOOGLE CALENDAR Y MEET (OPCIONAL) ───────────────────────────────────
# Sin esto, las citas se guardan igual en la base de datos.
# Para activarlo: https://console.cloud.google.com → APIs → Calendar API
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── ALMACENAMIENTO DE ARCHIVOS EXTERNO (OPCIONAL) ───────────────────────
# Sin esto, los archivos se guardan en la base de datos (hasta 10MB).
# Para archivos más grandes, activa Vercel Blob:
# En Vercel → Storage → Blob → Create Store → copia el token
BLOB_READ_WRITE_TOKEN=""
